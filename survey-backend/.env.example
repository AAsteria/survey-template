# MongoDB Atlas 连接串（免费 M0 集群）
# 在 https://cloud.mongodb.com 创建集群后获取
# 替换 <password> 为你的数据库用户密码
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/survey?retryWrites=true&w=majority

# API 鉴权密钥（admin 面板用，自定义一个复杂点的字符串）
API_SECRET=change-me-to-a-random-string

# 服务端口（Render 会自动注入 PORT）
PORT=3000
